<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        Legacy PPN tag from Odoo 17 and below. 
        Odoo 18 no longer defines it, so we provide this definition 
        to prevent deletion since it is still referenced by historical data.
    -->
    <data noupdate="1">
        <record id="l10n_id.ppn_tag" model="account.account.tag" forcecreate="1">
            <field name="name">PPN</field>
            <field name="applicability">taxes</field>
            <field name="country_id" ref="base.id" />
        </record>
    </data>
</odoo>