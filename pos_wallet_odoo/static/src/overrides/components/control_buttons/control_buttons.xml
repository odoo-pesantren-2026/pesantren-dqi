<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Mewarisi dari PaymentScreenValidate -->
        <t t-name="pos_wallet_odoo.ValidateBaypas" t-inherit="point_of_sale.PaymentScreenValidate" t-inherit-mode="extension">
            <!-- Mengganti tombol validate untuk Odoo 17 -->
            <xpath expr="//button[contains(@class, 'validation-button')]" position="replace">
                <button class="validation-button next btn btn-primary btn-lg py-3 lh-lg" 
                    t-attf-class="{{ ui.isSmall ? 'btn-switchpane flex-fill' : 'button next w-50' }} {{currentOrder.canBeValidated() ? 'highlight' : 'disabled'}}" 
                    t-on-click="() => this.clickSetSubTotal()">
                    <span class="next_text">Validate</span>
                </button>
            </xpath>
        </t>
</templates>